# ─────────────────────────────────────────────────────────────────────────────
# JAIKO! — Configuración del entorno Backend
# Copiá este archivo como ".env" y completá los valores según tu proyecto.
# ⚠️  NUNCA subas este archivo a GitHub. Está incluido en el .gitignore.
# ─────────────────────────────────────────────────────────────────────────────


# ── Entorno Flask ─────────────────────────────────────────────────────────────
# "development" activa el modo debug con recarga automática.
# Cambiarlo a "production" antes de publicar la app.
FLASK_ENV=development


# ── Clave secreta de Flask ────────────────────────────────────────────────────
# Usada para firmar sesiones y cookies internas de Flask.
# Cambiala por una cadena larga y aleatoria en producción.
SECRET_KEY=jaiko-secret-super-seguro-2024


# ── Base de datos PostgreSQL (Supabase) ───────────────────────────────────────
# Formato: postgresql://USUARIO:CONTRASEÑA@HOST:PUERTO/NOMBRE_BD
# Estos datos vienen de: Supabase → Project Settings → Database → Connection string
DATABASE_URL=postgresql://postgres.dmijrqufkllarvdlvvfn:hackatonjaiko@aws-0-us-west-2.pooler.supabase.com:5432/postgres?sslmode=require


# ── JWT (JSON Web Token) ──────────────────────────────────────────────────────
# Clave secreta usada para firmar los tokens de sesión de los usuarios en JAIKO!
# Cambiala por una cadena larga y aleatoria en producción.
JWT_SECRET_KEY=jaiko-jwt-secret-2024


# ── Google OAuth 2.0 ──────────────────────────────────────────────────────────
# Client ID de tu app en Google Cloud Console.
# Dónde obtenerlo: console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=579014137585-9gsqrocduq9av0repbqig6d9c55t455h.apps.googleusercontent.com


# ── Supabase Storage (para subir imágenes) ────────────────────────────────────
# URL del proyecto: Supabase → Project Settings → API → Project URL
SUPABASE_URL=https://dmijrqufkllarvdlvvfn.supabase.co

# Clave pública anónima: Supabase → Project Settings → API → anon public
SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImRtaWpycXVma2xsYXJ2ZGx2dmZuIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzM1MDg4MzgsImV4cCI6MjA4OTA4NDgzOH0.P5PrnpGK--8n5j6uC0KjNnDAYfdySh0mIVNv9JE5INU

# Nombre del bucket donde se guardarán las fotos de perfiles, departamentos, etc.
# Crealo en: Supabase → Storage → New bucket → Nombre: jaiko-media → Public: ON
SUPABASE_BUCKET=jaiko-media


# ── CORS — URL del frontend ───────────────────────────────────────────────────
# Le indica al backend desde qué origen puede recibir peticiones.
# En desarrollo apunta a Vite corriendo localmente.
# En producción cambiarlo por la URL real del frontend (ej: https://jaiko.com.py)
FRONTEND_URL=http://localhost:5173