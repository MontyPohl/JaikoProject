# ══════════════════════════════════════════════════════
#  JAIKO — .gitignore
#  Cubre: backend (Python), frontend (Vite), mobile (Expo)
# ══════════════════════════════════════════════════════

# ── Sistema operativo ──────────────────────────────────
.DS_Store
.DS_Store?
Thumbs.db
desktop.ini
*~

# ── Variables de entorno (NUNCA subir al repo) ─────────
.env
.env.local
.env.development
.env.production
.env.*.local

# ══════════════════════════════════════════════════════
#  BACKEND — Python / Flask
# ══════════════════════════════════════════════════════
.venv/
venv/
__pycache__/
**/__pycache__/
**/*.pyc
**/*.pyo
**/*.pyd
.pytest_cache/
instance/
*.db
*.sqlite3
migrations/versions/*.pyc

# ══════════════════════════════════════════════════════
#  FRONTEND — React / Vite
# ══════════════════════════════════════════════════════
node_modules/
dist/
.vite/
coverage/

# ══════════════════════════════════════════════════════
#  MOBILE — Expo / React Native
# ══════════════════════════════════════════════════════
node_modules/
.expo/
dist/
web-build/

# Carpetas nativas generadas por Expo (no editar a mano)
mobile/android/
mobile/ios/

# ══════════════════════════════════════════════════════
#  SHARED — no tiene node_modules propios
# ══════════════════════════════════════════════════════
shared/**/*.pyc

# ── Editor ─────────────────────────────────────────────
.vscode/settings.json
.idea/
*.swp
*.swo
